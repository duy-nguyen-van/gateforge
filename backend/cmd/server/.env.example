# Copy to .env and adjust for your machine. Do not commit .env.
# Run the API from cmd/server (or ensure .env is loaded from cwd): godotenv loads .env from the process working directory.

# -----------------------------------------------------------------------------
# Application (local)
# -----------------------------------------------------------------------------
APP_ENV=development
APP_NAME=backend
APP_VERSION=1.0.0
TIMEZONE=UTC
# HTTP listen address (matches curl examples when using localhost)
APP_HTTP_SERVER=:3000
APP_REQUEST_TIMEOUT=30
# Public base URL of this API — used for OIDC issuer, redirects, return_to checks (use http://localhost:3000 locally; use your ngrok URL when tunneling)
APP_BASE_URL=http://localhost:3000
# Serve embedded Vite SPA from the Go binary (hybrid single-binary deploy). Default: true in production, false in development.
SERVE_EMBEDDED_FRONTEND=false
# Optional: serve SPA from disk in dev when embed tag is not used (auto-detects backend/internal/static/dist).
# Run `make copy-frontend` after frontend changes. For same-origin on :3000 also set OIDC_LOGIN_PAGE_URL and WEBAUTHN_RP_ORIGINS to http://localhost:3000.
# FRONTEND_DIST_PATH=../../internal/static/dist
# Where GET /authorize sends unauthenticated users (your SPA login page). Defaults to APP_BASE_URL + "/login" if unset.
# With frontend Vite dev server:
OIDC_LOGIN_PAGE_URL=http://localhost:5173/login
# Production (same-origin hybrid deploy): set APP_BASE_URL=https://iam.example.com, SERVE_EMBEDDED_FRONTEND=true,
# OIDC_LOGIN_PAGE_URL=https://iam.example.com/login, WEBAUTHN_RP_ORIGINS=https://iam.example.com
LOG_LEVEL=debug

# WebAuthn — must include the browser origin (Vite :5173 in local dev, not the API port)
WEBAUTHN_RP_ID=localhost
WEBAUTHN_RP_ORIGINS=http://localhost:5173

# -----------------------------------------------------------------------------
# JWT (Phase 1 — /api/v1/login, /api/v1/me)
# -----------------------------------------------------------------------------
# Min ~32 characters recommended for non-dev environments
JWT_SECRET=local-dev-change-me-use-a-long-random-string!!
JWT_ACCESS_TTL=24h
JWT_REFRESH_TTL=168h
# Phase 3 — iam_session cookie: default TTL matches JWT_REFRESH_TTL when unset (0)
# SSO_SESSION_TTL=168h
# Longer cookie when login body sets remember_me: true
SSO_SESSION_REMEMBER_TTL=720h
# Refresh tokens for first-party login store this oauth_client_id
NATIVE_OAUTH_CLIENT_ID=native

# -----------------------------------------------------------------------------
# Multi-tenant default (must match seeded data / migrations)
# -----------------------------------------------------------------------------
DEFAULT_TENANT_ID=00000000-0000-0000-0000-000000000001

# -----------------------------------------------------------------------------
# Phase 4 — Federation (upstream OAuth/OIDC → iam_session → /authorize)
# -----------------------------------------------------------------------------
# OAuth credentials are stored per tenant in tenant_identity_providers (configure via admin console).
# ADMIN_API_KEY enables PATCH /api/v1/internal/tenants/:tenantId/identity-providers/:provider

# First-run platform admin bootstrap. Used only when no platform admins exist in DB.
# Creates a new user or promotes an existing user in DEFAULT_TENANT_ID.
BOOTSTRAP_ADMIN_EMAIL=
BOOTSTRAP_ADMIN_PASSWORD=

# -----------------------------------------------------------------------------
# OIDC Phase 2 — RS256 id/access tokens, JWKS
# -----------------------------------------------------------------------------
# Prefer file path for local dev (generate a 2048-bit RSA private key PEM):
#   openssl genrsa -out oidc-dev.pem 2048
OIDC_RSA_PRIVATE_KEY_FILE=
# Or inline PEM (multiline; rarely used in .env)
# OIDC_RSA_PRIVATE_KEY_PEM=
OIDC_KEY_ID=default-key-1
# Falls back to JWT TTLs when 0; set explicitly if needed
# OIDC_ACCESS_TTL=1h
# OIDC_ID_TOKEN_TTL=1h
OIDC_AUTH_CODE_TTL=10m

# -----------------------------------------------------------------------------
# PostgreSQL (local)
# -----------------------------------------------------------------------------
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=iam
DATABASE_DEBUG=false
DATABASE_SSL_MODE=disable
DATABASE_TIMEZONE=UTC

# -----------------------------------------------------------------------------
# Redis (local — empty password is fine for docker redis defaults)
# -----------------------------------------------------------------------------
CACHE_PROVIDER=redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# -----------------------------------------------------------------------------
# Rate limiting
# -----------------------------------------------------------------------------
DEFAULT_RATE_LIMIT=100
AUTH_RATE_LIMIT=30
PUBLIC_RATE_LIMIT=100
RATE_LIMIT_DURATION=1s

# -----------------------------------------------------------------------------
# Swagger (non-production)
# -----------------------------------------------------------------------------
BASIC_AUTH_USER=admin
BASIC_AUTH_SECRET=admin

# -----------------------------------------------------------------------------
# Optional integrations (leave empty for local auth-only testing)
# -----------------------------------------------------------------------------
SENTRY_DSN=
NEWRELIC_LICENSE=
NEWRELIC_APP_NAME=backend-local

EMAIL_PROVIDER=ses
AWS_SES_REGION=
AWS_SES_ACCESS_KEY=
AWS_SES_SECRET_KEY=

HTTP_CLIENT_TIMEOUT=30s
HTTP_CLIENT_RETRY_COUNT=2
HTTP_CLIENT_RETRY_WAIT_MIN=250ms
HTTP_CLIENT_RETRY_WAIT_MAX=2s
HTTP_CLIENT_DEBUG=false
HTTP_CLIENT_TLS_INSECURE_SKIP_TLS=false

STORAGE_PROVIDER=gcs
GCS_BUCKET=
GCS_CREDENTIALS_JSON=
S3_BUCKET=
S3_REGION=
S3_ACCESS_KEY=
S3_SECRET_KEY=

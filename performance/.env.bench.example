# Copy to .env.bench and source before running the server under test.
# High limits so k6 is not capped by middleware (production defaults stay 20/s and 3/min).

PERF_TENANT_ID=00000000-0000-0000-0000-000000000001
PERF_BASE_URL=http://127.0.0.1:3000
PERF_SIGNER_URL=http://127.0.0.1:9091
PERF_CLIENT_ID=oidc-dev
PERF_REDIRECT_URI=http://localhost:3000/callback
PERF_USER_EMAIL=perf-token@example.com
PERF_USER_PASSWORD=perf-token-passphrase-long!!

# Bench process (merge with backend/cmd/server/.env when starting the binary)
DEFAULT_RATE_LIMIT=1000000
AUTH_RATE_LIMIT=1000000
RATE_LIMIT_DURATION=1s
DATABASE_MAX_OPEN_CONNS=100
DATABASE_MAX_IDLE_CONNS=50
LOG_LEVEL=warn
SENTRY_DSN=
NEWRELIC_LICENSE=
SERVE_EMBEDDED_FRONTEND=false
WEBAUTHN_RP_ID=localhost
WEBAUTHN_RP_ORIGINS=http://localhost:3000
APP_BASE_URL=http://localhost:3000
APP_HTTP_SERVER=:3000
APP_ENV=production

# Token hold stage target (adjust after ramp finds the cliff)
PERF_HOLD_RPS=350
PERF_SEED_CODES=500000
PERF_PASSKEY_USERS=20
PERF_PASSKEY_VUS=10

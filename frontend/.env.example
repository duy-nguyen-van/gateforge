# Leave empty for same-origin (Vite dev proxy handles /api/v1 and OIDC paths).
# Production hybrid build (embedded in Go binary): leave empty — API is on the same origin.
VITE_API_BASE_URL=

# Backend proxy target for local dev (vite.config.ts).
VITE_API_PROXY_TARGET=http://localhost:3000

# Default tenant for WebAuthn login and federation provider lookup (matches backend DEFAULT_TENANT_ID).
VITE_DEFAULT_TENANT_ID=00000000-0000-0000-0000-000000000001

# Agentation — dev-only UI annotations synced to MCP (see https://www.agentation.com/install).
# Requires agentation-mcp server (already in .cursor/mcp.json). Default port: 4747.
# VITE_AGENTATION_ENDPOINT=http://localhost:4747

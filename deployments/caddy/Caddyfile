# Same-origin deployment: static SPA + Go API
#
# Usage (Fly.io / Railway / VPS):
#   1. cd frontend && npm run build  →  dist/
#   2. Copy dist/ to /srv/dist
#   3. Set API_UPSTREAM to your Go backend (e.g. http://127.0.0.1:3000)
#   4. caddy run --config deployments/caddy/Caddyfile

:{$PORT:8080} {
	root * /srv/dist
	encode gzip

	@api path /api/v1/*
	@oidc path /oidc/*
	@authorize path /authorize
	@token path /token
	@userinfo path /userinfo
	@wellknown path /.well-known/*

	handle @api {
		reverse_proxy {$API_UPSTREAM:localhost:3000}
	}
	handle @oidc {
		reverse_proxy {$API_UPSTREAM:localhost:3000}
	}
	handle @authorize {
		reverse_proxy {$API_UPSTREAM:localhost:3000}
	}
	handle @token {
		reverse_proxy {$API_UPSTREAM:localhost:3000}
	}
	handle @userinfo {
		reverse_proxy {$API_UPSTREAM:localhost:3000}
	}
	handle @wellknown {
		reverse_proxy {$API_UPSTREAM:localhost:3000}
	}

	try_files {path} /index.html
	file_server
}
